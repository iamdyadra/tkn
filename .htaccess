<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── [PENTING] Biarkan request ke /api/ diproses PHP langsung ──
  RewriteRule ^api/ - [L]

  # ── Arahkan root request ke React SPA ─────────────────────────
  RewriteRule ^$ index.html [L]

  # ── Layani aset statis (js, css, images, fonts) ────────────────
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # ── Semua route lain → React Router (SPA fallback) ────────────
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ index.html [L]

</IfModule>


